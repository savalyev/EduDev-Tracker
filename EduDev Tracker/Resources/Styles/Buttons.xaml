<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="EduPrimaryButtonBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource EduButtonBackground}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 15" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="HorizontalOptions" Value="Start" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style x:Key="EduPrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="Comfortaa" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource EduPrimaryText}" />
        <Setter Property="Padding" Value="0" />
    </Style>

</ResourceDictionary>