<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="EduCardBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource EduBackground}" />
        <Setter Property="Stroke" Value="{StaticResource EduCardBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 15" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="EduProgressBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource EduBackground}" />
        <Setter Property="Stroke" Value="{StaticResource EduCardBorder}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="EduEmptyStateBorder" TargetType="Border">
        <Setter Property="BackgroundColor" Value="#900F121C" />
        <Setter Property="StrokeShape" Value="RoundRectangle 15" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="20" />
    </Style>

</ResourceDictionary>